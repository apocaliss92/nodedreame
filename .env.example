# nodedreame — example environment for real-device e2e tests.
# Copy to .env and fill in real values. .env is gitignored and must NEVER be committed.

# Account type: dreame | mova | trouver  (this project targets the Dreamehome cloud)
DREAME_ACCOUNT_TYPE=dreame

# Dreamehome account credentials
DREAME_USERNAME=
DREAME_PASSWORD=

# Account region/country code as used by the Dreamehome cloud (e.g. eu, us, cn, sg).
# Italy / Europe is normally "eu".
DREAME_COUNTRY=eu

# Gate for the real-device e2e suite. Set to 1 to enable (tests run only on the LAN/online).
DREAME_E2E=0
